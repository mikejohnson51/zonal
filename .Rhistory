} else if(FUN == "min"){
FUN = function(x, w) { suppressWarnings(min(x, na.rm = TRUE)) }
} else {
stop("FUN not valid...")
}
FUN
threds = getDTthreads()
setDTthreads(0)
exe = dt[, lapply(.SD, FUN = FUN, w = w), keyby = eval(ID), .SDcols = cols]
setDTthreads(threds)
