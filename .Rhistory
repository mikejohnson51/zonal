data = pr_zone %>%
slice_max(rowSums(select(., -geoid))) %>%
pivot_longer(-geoid, names_to = "day", values_to = "prcp") %>%
mutate(day = as.numeric(gsub("V","", day)))
head(data)
ggplot(data, aes(x = day, y = prcp))  +
geom_line() +
labs(x = "Date", y = "Mean Rainfall",
title = paste("GEOID: ", data$geoid[1])) +
theme_bw()
