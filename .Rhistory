} else {
z = file
}
tmp = ext(c(
xFromCol(z, dims[1]),
xFromCol(z, dims[2]),
yFromRow(z, dims[3]),
yFromRow(z, dims[4])
))
terra::window(z) <- terra::align(tmp, z, snap = "out")
df = terra::as.data.frame(z, na.rm = FALSE)
names(df) <- paste0('V', 1:ncol(df))
df$grid_id = 1:nrow(df)
setDT(df, key = "grid_id")
if(terra::windo(z)){
window(z) <- NULL
}
return(df)
}
