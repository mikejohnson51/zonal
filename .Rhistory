}
} else if(FUN == "circular_mean") {
area_weight = FALSE
FUN <- function (x) {
degrad = pi / 180
sinr <- sum(sin(x * degrad), na.rm = T)
cosr <- sum(cos(x * degrad), na.rm = T)
val = atan2(sinr, cosr) * (1 / degrad)
ifelse(val < 0, 180 + (val + 180), val)
}
} else {
stop("FUN not valid...")
}
FUN
