} else if(FUN == "gm_mean"){
FUN = function(x, w) { suppressWarnings(gm_mean(x)) }
} else {
stop("FUN not valid...")
}
exe = dt[, lapply(.SD, FUN = FUN, w = w), keyby = eval(ID), .SDcols = cols]
exe = setnames(exe, c(ID, name))
}
exe
